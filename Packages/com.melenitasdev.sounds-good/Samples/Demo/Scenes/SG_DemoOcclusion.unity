  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Welcome! This scene is designed to help you test the audio occlusion system
    in Sounds Good.\n\n- Use WASD + Mouse to move around the house in first person.\n-
    The speaker inside the house is playing music continuously.\n- Use E key to press
    the button in front of the house to enable or disable sound occlusion.\n- With
    occlusion enabled, walk around the exterior walls and notice how the sound becomes
    muffled when there\u2019s geometry between you and the speaker.\n- Move to the
    open window to hear the difference between direct sound and occluded sound.\n-
    You can also walk up the ramp and listen from the roof to test vertical occlusion
    behavior.\n\nBefore testing, make sure occlusion is enabled in the settings:\nTools
    \u2192 Melenitas Dev \u2192 Sounds Good \u2192 Settings\nInside that window,
    ensure that Occlusion is turned ON, otherwise the effect will not work.\n\nEnjoy
    experimenting with the system!"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 20f14168ebebe2744b2a3ec903b7a391, type: 2}
